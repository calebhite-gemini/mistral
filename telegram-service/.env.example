# ============================================================================
# Telegram Service Configuration
# ============================================================================
#
# Copy this file to .env and fill in your actual credentials:
#   cp .env.example .env
#
# Then edit .env with your values (never commit .env to version control!)
#

# ============================================================================
# REQUIRED: Telegram Bot Configuration
# ============================================================================
# Get your bot token from @BotFather on Telegram:
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow the prompts
# 3. Copy the token provided (format: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================================================
# REQUIRED: Kalshi API Configuration
# ============================================================================
# Get your API key from your Kalshi account:
# 1. Log in to https://kalshi.com
# 2. Go to Settings → API
# 3. Click "Generate New API Key"
# 4. Copy the key (keep it secure!)
KALSHI_API_KEY=your_kalshi_api_key_here

# ============================================================================
# OPTIONAL: Kalshi WebSocket URL
# ============================================================================
# Production endpoint (default - leave as is unless you know what you're doing)
KALSHI_WEBSOCKET_URL=wss://api.elections.kalshi.com/market_lifecycle_v2

# For demo/testing (if Kalshi provides a test endpoint):
# KALSHI_WEBSOCKET_URL=wss://demo-api.kalshi.com/market_lifecycle_v2

# ============================================================================
# OPTIONAL: Logging Configuration
# ============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# - DEBUG: Detailed information for debugging
# - INFO: General informational messages (recommended)
# - WARNING: Warning messages only
# - ERROR: Error messages only
LOG_LEVEL=INFO
